# AurumPulse environment configuration
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# .env git'e commit edilmez (bkz. .gitignore).

# ─── Flask ───
# Session imzalama için. Boş bırakılırsa random üretilir (restart'larda invalidate olur).
FLASK_SECRET_KEY=

# Hassas POST endpoint'lerini koruyan API key. Zorunlu — set etmezseniz startup'ta random üretilir.
# Frontend bu key'i X-API-Key header'ı veya JSON body'deki "api_key" alanı ile gönderir.
API_KEY=

# CORS origin'leri — virgülle ayrılmış. Production'da domain'i kısıtlayın.
# Örnek: CORS_ORIGINS=https://aurumpulse.example.com,https://admin.example.com
# Dev için: * (wildcard)
CORS_ORIGINS=*

# ─── Telegram ───
# Boş bırakılırsa Telegram devre dışı kalır.
# Token'ı BotFather'dan /newbot veya /revoke ile alın.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Price feed API keys ───
# TwelveData — XAU/USD gerçek zamanlı fiyat (free tier: 800 kredi/gün).
# Boş bırakılırsa altın fetch çalışmaz (sadece PAXG/gold-api fallback kalır).
# Key al: https://twelvedata.com/account/api-keys
TWELVEDATA_API_KEY=

# Finnhub — ekonomik takvim. Boş bırakılırsa takvim özelliği kapalı kalır.
# Key al: https://finnhub.io/register (ücretsiz)
FINNHUB_API_KEY=
